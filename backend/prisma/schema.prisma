generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CheckupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CheckupItemStatus {
  PENDING
  SCHEDULED
  COMPLETED
  SKIPPED
}

enum FacilityType {
  HOSPITAL
  PHARMACY
  CLINIC
  LABORATORY
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @default("x")
  phone        String?
  document     String?
  birthDate    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  checkups     Checkup[]
  assessments  MentalHealthAssessment[]

  @@map("users")
}

model Checkup {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  year       Int
  targetDate DateTime
  status     CheckupStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  items      CheckupItem[]

  @@unique([userId, year])
  @@map("checkups")
}

model CheckupItem {
  id               String            @id @default(uuid())
  checkupId        String
  checkup          Checkup           @relation(fields: [checkupId], references: [id])
  examType         String
  professionalType String
  category         String
  status           CheckupItemStatus @default(PENDING)
  scheduledDate    DateTime?
  completedDate    DateTime?
  notes            String?
  fileUrl          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("checkup_items")
}

model MentalHealthAssessment {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  assessedAt       DateTime  @default(now())
  overallRiskLevel RiskLevel @default(LOW)
  responses        String?
  isAnonymous      Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@map("mental_health_assessments")
}

model Facility {
  id          String       @id @default(uuid())
  name        String
  type        FacilityType
  address     String
  phone       String?
  lat         Float
  lng         Float
  openHours   String?
  is24h       Boolean      @default(false)
  rating      Float        @default(0)
  ratingCount Int          @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("facilities")
}

model MentalHealthAction {
  id            String       @id @default(uuid())
  title         String
  description   String?
  riskDimension String?
  assignedTo    String?
  dueDate       DateTime
  status        ActionStatus @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("mental_health_actions")
}