# Root .dockerignore (build context = repo root for both Railway + docker-compose)
# Excludes everything not needed by either backend or frontend builds.

# Dependencies
**/node_modules
backend/node_modules
frontend/node_modules

# Build outputs
**/dist
**/.next
backend/dist
frontend/.next

# Tests & coverage
**/coverage
**/__tests__
backend/test
backend/coverage
frontend/coverage

# Infra & docs (not needed in build)
infra
docs
skills
.github

# Env & secrets
**/.env
**/.env.local
**/.env.example

# Misc
.git
.gitignore
.DS_Store
*.log
README.md
redis-staging/**